# העתק קובץ זה ל-.env ומלא את המפתחות
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# אופציונלי — לעקיפת ברירות המחדל
# CLAUDE_MODEL=claude-opus-4-8
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# פרוקסי (למשל עבור SSH Tunnel / SOCKS5)
# אם הרצת: ssh -N -D 1080 -p 2233 root@tamleluya.com
# השתמש בכתובת הבאה:
GEMINI_PROXY=socks5://127.0.0.1:1080
