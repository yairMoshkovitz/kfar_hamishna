(function () {
    var domain = "netfree.link";

    //old browser
    if (!window.fetch || ![].forEach) return;
    var listIframes = ["//" + domain + "/misc/go-payment.html?v=3"];
    listIframes.forEach(function (iframeLink) {
        try {
            var iframe = document.createElement('iframe');
            iframe.style.height = '0px';
            iframe.style.width = '0px';
            iframe.style.display = 'none';
            iframe.src = iframeLink;
            document.documentElement.appendChild(iframe);
        } catch (e) { }
    });
    var actions = {};
    actions['redirect'] = function (e) {
        var link = e.data.link;
        window.addEventListener("mousemove", function () {
            window.location = link;
        });
    };
    actions['popup'] = function (e) {
        var link = e.data.link;
        var addElm = document.createElement("div");
        addElm.innerHTML = "\n        <div style=\"z-index: 99999999;position: fixed;top: 0;left: 0;right: 0;bottom: 0;display: flex;align-items: center;justify-content: center;background: rgba(0, 0, 0, 0.45);backdrop-filter: blur(2px);\">\n            <div style=\"position: relative;width: min(90vw, 720px);height: min(75vh, 470px);\">\n                <button style=\"position: absolute;top: 6px;right: 6px;padding: 8px;border: 0;border-radius: 999px;background: rgba(255, 255, 255, 0.92);color: #111;font: 600 13px/1.2 system-ui, -apple-system, sans-serif;cursor: pointer;box-shadow: 0 6px 16px rgba(0,0,0,0.25);\" class=\"close\" aria-label=\"Close\">\n                    <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" style=\"display: block\">\n                        <path d=\"M6 6l12 12M18 6l-12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"></path>\n                    </svg>\n                </button>\n                <iframe style=\"width: 100%;height: 100%;border: 1px solid rgba(0,0,0,0.25);border-radius: 14px;background: #ffffff;box-shadow: 0 18px 50px rgba(0,0,0,0.35);\" src=\"\"></iframe>\n            </div>\n        </div>\n            ";
        var closeElm = addElm.querySelector(".close");
        closeElm.addEventListener('click', function (ev) {
            addElm.parentElement.removeChild(addElm);
        });
        var iframeElm = addElm.querySelector("iframe");
        iframeElm.src = link;
        document.documentElement.appendChild(addElm);
    };
    window.addEventListener('message', function (e) {
        if (e.origin.replace(/^https?:\/\//g, '') === domain) {
            var action = e.data.action;
            if (actions[action]) actions[action](e);
        }
    }, false);
})();
